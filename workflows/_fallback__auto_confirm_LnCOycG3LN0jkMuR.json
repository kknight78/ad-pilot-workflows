  "nodes": [
    {
      "id": "trigger-cron",
      "name": "Wednesday 6pm CT",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        0,
        300
      ],
      "parameters": {
        "rule": {
          "interval": [
